[gd_resource type="Resource" script_class="DialogicGlossary" format=3 uid="uid://b6f6js5mp1oja"]

[ext_resource type="Script" uid="uid://80elcodyqohb" path="res://addons/dialogic/Modules/Glossary/glossary_resource.gd" id="1_h07jx"]

[resource]
script = ExtResource("1_h07jx")
entries = {
"aperriada": {
"case_sensitive": true,
"color": Color(0.94509804, 1, 0, 0.9882353),
"name": "aperriada",
"text": "Uma pessoa aperreada (ou aperriada) é alguém que se encontra em um estado de grande ansiedade, preocupação, agitação, estresse ou aflição com alguma situação específica.",
"title": "O que é?"
},
"caba macho": {
"case_sensitive": true,
"color": Color(0.94509804, 1, 0, 0.9882353),
"name": "caba macho",
"text": "Cabra macho\" é uma expressão popular, muito comum no Nordeste brasileiro, utilizada para descrever um homem valente, corajoso, destemido e determinado",
"title": "O que é?"
},
"empaiar": {
"name": "empaiar",
"text": "\"Empaiar\" é um termo regional, comumente usado no Nordeste brasileiro, que significa atrapalhar, consumir o tempo de alguém, fazer perder tempo ou enrolar",
"title": "O que é?"
},
"fulero": {
"case_sensitive": false,
"color": Color(0.9453125, 1, 0, 1),
"name": "fulero",
"text": "Fuleiro é um adjetivo coloquial brasileiro usado para descrever algo ou alguém de má qualidade, sem valor, reles ou irresponsável. Pode significar algo ordinário, cafona, brega ou pouco confiável. É comum no Nordeste e varia em gênero (fuleiro/fuleira) e número.",
"title": "O que é?"
},
"mói": {
"case_sensitive": true,
"color": Color(0.94509804, 1, 0, 1),
"name": "mói",
"text": "Comum no Ceará e Nordeste, significa uma grande quantidade, ruma, montão ou pilha.",
"title": "O que é?"
},
"peia": {
"color": Color(0.94509804, 1, 0, 0.9882353),
"name": "peia",
"text": "No Nordeste brasileiro, peia refere-se popularmente a uma surra, castigo físico, açoite ou uma grande sova",
"title": "O que é?"
}
}
